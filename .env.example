# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=vidbee

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=dont_get_zoned
JWT_EXPIRES_IN=7d

# ─── Gemini (AI quiz generation) ───────────────────────────────────────────
# Get a key from Google AI Studio and set it here.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional (defaults to gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview

# ─── Client URL (for CORS) ──────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Google OAuth (Continue with Google) ───────────────────────────────────
# Create OAuth Client ID in Google Cloud Console.
# Authorized redirect URI MUST match GOOGLE_CALLBACK_URL (and what you set in the console).
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback